# API KEYS CONFIGURATION
# Rellena estos valores con tus claves reales.

# OpenAI (Para GPT-4o / Core) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic (Para Claude Coding / Navigation) - https://console.anthropic.com/settings/keys
# Necesita saldo (Créditos) no solo suscripción Pro.
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (Para Antigravity / Análisis Masivo) - https://aistudio.google.com/app/apikey
# Gratis en AI Studio para modelos Pro.
GEMINI_API_KEY=AIza...

# Otras configuraciones
# URL de Webhook de n8n (si tienes uno configurado)
N8N_WEBHOOK_URL=
